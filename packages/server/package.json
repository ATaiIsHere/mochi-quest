{
  "name": "@mochi-quest/server",
  "version": "0.1.0",
  "description": "Mochi Quest MCP Server + REST API",
  "type": "module",
  "bin": {
    "mochi-quest": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts start",
    "start": "node dist/index.js start",
    "start:daemon": "node dist/index.js start --daemon",
    "mcp": "node dist/index.js mcp"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.15.0",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.7.11",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
